# Splits — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# ---- Appwrite (Auth + Databases) ----
# Public — bundled into client JS
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=6a17843500336b1e97d8
NEXT_PUBLIC_APPWRITE_DATABASE_ID=splits

# Server-only — Appwrite admin API key (Console → API Keys → Create)
# Needed scopes: databases.read, databases.write, collections.read, collections.write,
#                attributes.read, attributes.write, indexes.read, indexes.write,
#                users.read, sessions.write
APPWRITE_API_KEY=

# ---- Secret encryption (32 bytes hex, generate with: openssl rand -hex 32) ----
ENCRYPTION_KEY=

# ---- Strava OAuth (strava.com/settings/api) ----
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random string you choose; Strava echoes it back when verifying webhook subscription
STRAVA_WEBHOOK_VERIFY_TOKEN=

# ---- App URL (used for OAuth callbacks) ----
# In production set this to your deployed URL (e.g. https://splits.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
