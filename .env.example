# Splits — environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# ---- Supabase (Auth + Postgres + RLS) ----
# Public — bundled into client JS
# For self-hosted: this is the Kong API gateway URL (typically https://your-host:8443 or via reverse proxy).
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-host
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — service role key (Supabase Studio → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Secret encryption (32 bytes hex, generate with: openssl rand -hex 32) ----
ENCRYPTION_KEY=

# ---- Strava OAuth (strava.com/settings/api) ----
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random string you choose; Strava echoes it back when verifying webhook subscription
STRAVA_WEBHOOK_VERIFY_TOKEN=

# ---- App URL (used for OAuth callbacks) ----
# In production: deployed URL (e.g. https://6a186ef666fb750d3818.appwrite.network)
NEXT_PUBLIC_APP_URL=http://localhost:3000
